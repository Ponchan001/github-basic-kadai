      "source": [
        "# 消費税を加えた金額を計算する関数\n",
        "def calc_tax(price, tax_rate):\n",
        "    # 税込金額を計算して戻り値として返す\n",
        "    total = price + (price * tax_rate / 100)\n",
        "    return total\n",
        "\n",
        "# 第1引数：商品の金額 110\n",
        "# 第2引数：消費税 10%\n",
        "result = calc_tax(110, 10)\n",
        "\n",
        "print(\"税込金額は\", result, \"円です\")\n"
      ]
    }
  ]
}