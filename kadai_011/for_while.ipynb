      "source": [
        "# 対象のリスト（水星〜冥王星）\n",
        "array = [\"水\", \"金\", \"地\", \"火\", \"木\", \"土\", \"天\", \"海\", \"冥\"]\n",
        "\n",
        "# --- forループで出力 ---\n",
        "for i in array:\n",
        "    print(i)\n",
        "\n",
        "# --- whileループで出力 ---\n",
        "index = 0\n",
        "while index < len(array):\n",
        "    print(array[index])\n",
        "    index = index+1\n"
      ]
