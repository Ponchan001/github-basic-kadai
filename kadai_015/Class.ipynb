      "source": [
        "class Human:\n",
        "    def __init__(self, name, age):\n",
        "        self.name = name\n",
        "        self.age = age\n",
        "\n",
        "    def printinfo(self):\n",
        "        print(\"名前:\", self.name)\n",
        "        print(\"年齢:\", self.age)\n",
        "\n",
        "\n",
        "# Humanクラスのインスタンスを作成\n",
        "person = Human(\"TARO\", 30)\n",
        "\n",
        "# メソッドを呼び出して情報を表示\n",
        "person.printinfo()\n",
        "\n"
      ]
    }
  ]
